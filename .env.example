# Database
DATABASE_URL=postgres://localhost:5432/taskhub_v2?sslmode=disable

# Server
PORT=8080

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session encryption (change in production)
SESSION_SECRET=change-me-in-production

# Symmetric key for encrypting agent auth configs at rest
TASKHUB_SECRET_KEY=

# LLM provider
ANTHROPIC_API_KEY=

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000
